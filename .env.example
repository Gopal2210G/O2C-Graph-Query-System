# Google Generative AI (Gemini) - optional
GOOGLE_API_KEY=your_google_api_key_here

# Groq AI - required for LLM hybrid query support
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Server configuration
HOST=0.0.0.0
PORT=3000

# Debug mode
DEBUG=False

# ============================================================================
# OPTIONAL - Data & Paths
# ============================================================================

# Path to SAP O2C data folder containing JSONL files
# Default: ./sap-o2c-data
DATA_PATH=./sap-o2c-data

# ============================================================================
# OPTIONAL - Server Configuration
# ============================================================================


# ============================================================================
# OPTIONAL - Logging
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL - LLM Configuration
# ============================================================================

# Groq model to use (keep as is unless you want to experiment)
LLM_MODEL=llama-3.3-70b-versatile

# Temperature for LLM creativity (0.0 = deterministic, 1.0 = creative)
# Use 0.3 for SQL generation (deterministic)
# Use 0.5-0.7 for response synthesis (balanced)
SQL_GENERATION_TEMPERATURE=0.3
RESPONSE_SYNTHESIS_TEMPERATURE=0.5

# ============================================================================
# OPTIONAL - Database Configuration
# ============================================================================

# SQLite query timeout in seconds
DB_QUERY_TIMEOUT=5

# Maximum rows returned per query
DB_MAX_RESULTS=1000

# Enable PRAGMA optimizations
DB_ENABLE_PRAGMAS=true

# ============================================================================
# OPTIONAL - Security
# ============================================================================

# Allowed table names (comma-separated, or leave as built-in whitelist)
# ALLOWED_TABLES=sales_order_headers,billing_document_headers,...

# Enable query logging (for audit purposes)
ENABLE_QUERY_LOGGING=false

# Log file path (if logging enabled)
QUERY_LOG_FILE=./query_log.txt

# ============================================================================
# OPTIONAL - Frontend
# ============================================================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=*

# Frontend title
APP_TITLE=Order-to-Cash Graph System

# ============================================================================
# Notes
# ============================================================================
#
# 1. Download data from Google Drive link in README.md
# 2. Get Groq API key at https://console.groq.com (free tier available)
# 3. For production, use strong security practices
# 4. Never commit this file with real credentials to version control
#
